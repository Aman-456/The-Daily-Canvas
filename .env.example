NEXT_PUBLIC_APP_URL="https://your-domain.example"

# Home: number of archive cards before “Show more” → /archive (6 or 9; default 9)
# NEXT_PUBLIC_HOME_ARCHIVE_TEASER="9"

# /archive listing page size when not searching or filtering (6, 9, or 12; default 12)
# NEXT_PUBLIC_HOME_BLOG_GRID_SIZE="12"

# Auth (NextAuth / Auth.js)
NEXTAUTH_SECRET="replace_me"
AUTH_SECRET="replace_me"

# Database
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
MONGODB_URI="mongodb://user:password@host:27017/db"

# OAuth (Google)
AUTH_GOOGLE_ID="replace_me.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="replace_me"

# Dev-only admin login (Credentials provider; enabled only when NODE_ENV=development)
DEV_ADMIN_EMAIL="admin@example.com"
DEV_ADMIN_PASSWORD="replace_me"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="replace_me"

